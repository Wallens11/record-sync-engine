# Record source API
SOURCE_API_BASE_URL=https://records.example.com/api
SOURCE_API_TOKEN=your-source-api-token
# Or basic auth:
# SOURCE_BASIC_USERNAME=user@example.com
# SOURCE_BASIC_PASSWORD=your-password
SOURCE_WEBHOOK_TOKEN=random-secret-string

# Zendesk (required if any rule uses destination.type = "zendesk")
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=admin@example.com
ZENDESK_API_TOKEN=your-zendesk-api-token

# HubSpot (required if any rule uses destination.type = "hubspot")
# Create a Private App at: Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.read + crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN=your-private-app-token
HUBSPOT_PORTAL_ID=12345678

# Slack (required if any rule uses destination.type = "slack")
# Create a Bot at: api.slack.com/apps → OAuth & Permissions
# Scopes needed: chat:write, chat:write.public (or invite bot to target channels)
SLACK_BOT_TOKEN=your-slack-bot-token
